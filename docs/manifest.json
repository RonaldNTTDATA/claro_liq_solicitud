{
	"_version": "1.59.0",
	"sap.app": {
		"id": "com.demo.prototype",
		"type": "application",
		"i18n": "i18n/i18n.properties",
		"applicationVersion": {
			"version": "0.0.1"
		},
		"title": "{{appTitle}}",
		"description": "{{appDescription}}",
		"resources": "resources.json",
		"sourceTemplate": {
			"id": "@sap/generator-fiori:basic",
			"version": "1.20.1",
			"toolsId": "80cdac0e-fba7-4bee-b6fe-08fc70e80d96"
		}
	},
	"sap.ui": {
		"technology": "UI5",
		"icons": {
			"icon": "",
			"favIcon": "",
			"phone": "",
			"phone@2": "",
			"tablet": "",
			"tablet@2": ""
		},
		"deviceTypes": {
			"desktop": true,
			"tablet": true,
			"phone": true
		}
	},
	"sap.ui5": {
		"flexEnabled": true,
		"dependencies": {
			"minUI5Version": "1.120.0",
			"libs": {
				"sap.m": {},
				"sap.ui.core": {},
				"sap.f": {},
				"sap.ui.layout": {},
				"sap.ui.unified": {}
			}
		},
		"contentDensities": {
			"compact": true,
			"cozy": true
		},
		"models": {
			"i18n": {
				"type": "sap.ui.model.resource.ResourceModel",
				"settings": {
					"bundleName": "com.demo.prototype.i18n.i18n"
				}
			}
		},
		"resources": {
			"css": [
				{
					"uri": "css/style.css"
				}
			]
		},
		"routing": {
			"config": {
				"routerClass": "sap.m.routing.Router",
				"viewType": "XML",
				"async": true,
				"viewPath": "com.demo.prototype.view",
				"controlAggregation": "pages",
				"controlId": "app",
				"clearControlAggregation": false
			},
			"routes": [
				{
					"name": "login",
					"pattern": "login",
					"target": ["TargetLogin"]
				},
				{
					"name": "projectList",
					"pattern": "",
					"target": ["TargetProjectList"]
				},
				{
					"name": "projectDetail",
					"pattern": "project/{projectId}",
					"target": ["TargetProjectDetail"]
				}
			],
			"targets": {
				"TargetLogin": {
					"viewType": "XML",
					"transition": "slide",
					"clearControlAggregation": false,
					"viewId": "Login",
					"viewName": "Login"
				},
				"TargetProjectList": {
					"viewType": "XML",
					"transition": "slide",
					"clearControlAggregation": false,
					"viewId": "ProjectList",
					"viewName": "ProjectManagement.ProjectList"
				},
				"TargetProjectDetail": {
					"viewType": "XML",
					"transition": "slide",
					"clearControlAggregation": false,
					"viewId": "ProjectDetail",
					"viewName": "ProjectManagement.ProjectDetail"
				}
			}
		},
		"rootView": {
			"viewName": "com.demo.prototype.view.App",
			"type": "XML",
			"async": true,
			"id": "App"
		}
	}
}
