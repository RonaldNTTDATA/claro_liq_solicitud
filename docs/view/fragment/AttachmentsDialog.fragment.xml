<core:FragmentDefinition
	xmlns="sap.m"
	xmlns:core="sap.ui.core"
	xmlns:unified="sap.ui.unified">
	<Dialog
		id="attachmentsDialog"
		title="Adjuntar Sustentos - {attachmentModel>/projectCode}"
		contentWidth="600px"
		contentHeight="500px"
		resizable="true"
		draggable="true">
		<content>
			<VBox class="sapUiSmallMargin">
				<MessageStrip
					text="Debe adjuntar obligatoriamente un Acta de Cierre y un Informe Técnico. También puede adjuntar otros documentos."
					type="Information"
					showIcon="true"
					class="sapUiSmallMarginBottom" />
				
				<Label text="Tipo de adjunto:" class="sapUiTinyMarginBottom" />
				<Select
					selectedKey="{attachmentModel>/selectedType}"
					items="{attachmentModel>/attachmentTypeOptions}"
					class="sapUiSmallMarginBottom">
					<core:Item key="{attachmentModel>key}" text="{attachmentModel>text}" />
				</Select>

				<!-- File Uploader -->
				<Label text="Seleccionar archivo:" class="sapUiTinyMarginBottom" />
				
				<!-- Simple FileUploader -->
				<HBox alignItems="Center" class="sapUiSmallMarginTop">
					<unified:FileUploader
						id="fileUploader"
						name="fileUpload"
						uploadUrl=""
						placeholder="Seleccione un archivo PDF, Excel o Word"
						fileType="pdf,xlsx,xls,docx,doc"
						mimeType="application/pdf,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document"
						maximumFileSize="10"
						change=".onFileSelected"
						width="100%" />
					<Button
						icon="sap-icon://add"
						type="Emphasized"
						tooltip="Agregar archivo"
						press=".onAddAttachment"
						class="sapUiTinyMarginBegin" />
				</HBox>
				
				<!-- Lista de archivos adjuntos -->
				<VBox class="sapUiSmallMarginTop">
					<Label text="Acta de Cierre (obligatorio)" class="sapUiTinyMarginBottom" design="Bold" />
					<List
						mode="Delete"
						delete=".onRemoveAttachment"
						items="{attachmentModel>/actaAttachments}"
						noDataText="No adjuntado">
						<StandardListItem
							title="{attachmentModel>fileName}"
							description="{attachmentModel>fileSize}"
							icon="sap-icon://document-text"
							type="Active"
							press=".onDownloadAttachment">
							<customData>
								<core:CustomData key="index" value="{attachmentModel>index}" />
							</customData>
						</StandardListItem>
					</List>

					<Label text="Informe Técnico (obligatorio)" class="sapUiSmallMarginTop sapUiTinyMarginBottom" design="Bold" />
					<List
						mode="Delete"
						delete=".onRemoveAttachment"
						items="{attachmentModel>/informeAttachments}"
						noDataText="No adjuntado">
						<StandardListItem
							title="{attachmentModel>fileName}"
							description="{attachmentModel>fileSize}"
							icon="sap-icon://doc-attachment"
							type="Active"
							press=".onDownloadAttachment">
							<customData>
								<core:CustomData key="index" value="{attachmentModel>index}" />
							</customData>
						</StandardListItem>
					</List>

					<Label text="Otros adjuntos" class="sapUiSmallMarginTop sapUiTinyMarginBottom" design="Bold" />
					<List
						mode="Delete"
						delete=".onRemoveAttachment"
						items="{attachmentModel>/otherAttachments}"
						noDataText="No hay archivos adjuntos">
						<StandardListItem
							title="{attachmentModel>fileName}"
							description="Tipo: {attachmentModel>typeLabel} | {attachmentModel>fileSize}"
							icon="sap-icon://document"
							type="Active"
							press=".onDownloadAttachment">
							<customData>
								<core:CustomData key="index" value="{attachmentModel>index}" />
							</customData>
						</StandardListItem>
					</List>
				</VBox>
			</VBox>
		</content>
		<beginButton>
			<Button
				text="Cerrar"
				press=".onCloseAttachmentsDialog" />
		</beginButton>
	</Dialog>
</core:FragmentDefinition>
